# Dependencies - ignore node_modules everywhere
node_modules/
**/node_modules/
/node_modules
/backend/node_modules
/frontend/node_modules

# Environment and secrets - never commit
.env
.env.*
.env.local
.env.development
.env.production
.env*.local
# Keep example files
!.env.example
!**/.env.example

# Build outputs
dist/
build/
.next/
out/

# Logs and debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
*.log

# OS and editor
.DS_Store
Thumbs.db
*.swp
*.swo
.idea/
.vscode/
*.sublime-*

# Testing and coverage
coverage/
.nyc_output/
*.lcov

# Local uploads (backend)
backend/uploads/

# Misc
*.tsbuildinfo
.turbo
