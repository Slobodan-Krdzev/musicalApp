# ─── Local dev ───
MONGODB_URI=mongodb://localhost:27017/musical-app
PORT=4000
FRONTEND_URL=http://localhost:3000
APP_URL=http://localhost:4000

JWT_ACCESS_SECRET=change-me-access
JWT_REFRESH_SECRET=change-me-refresh
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Optional: absolute path for uploads (default: ./uploads next to src/)
UPLOAD_DIR=

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO=
STRIPE_PRICE_PREMIUM=

# ─── Email (Resend) ───
# 1) Create an API key (starts with "re_")
# 2) For dev, you can use: GigConnection <onboarding@resend.dev>
RESEND_API_KEY=
EMAIL_FROM=GigConnection <onboarding@resend.dev>

# Legacy SMTP (optional; only used if RESEND_API_KEY is not set)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# ─── Production (VPS example: api.gig-connection.com) ───
# NODE_ENV=production
# MONGODB_URI=mongodb://127.0.0.1:27017/gigconnection
# FRONTEND_URL=https://gig-connection.com,https://www.gig-connection.com
# APP_URL=https://api.gig-connection.com
# UPLOAD_DIR=/var/www/gigconnection/data/uploads
# (Use new random secrets, not the dev placeholders above)
