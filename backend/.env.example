# ─── Local dev ───
MONGODB_URI=mongodb://localhost:27017/musical-app
PORT=4000
FRONTEND_URL=http://localhost:3000
APP_URL=http://localhost:4000

JWT_ACCESS_SECRET=change-me-access
JWT_REFRESH_SECRET=change-me-refresh
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Optional: absolute path for uploads (default: ./uploads next to src/)
UPLOAD_DIR=

# ─── Stripe ───
# STRIPE_SECRET_KEY: secret key (sk_test_... / sk_live_...)
# STRIPE_WEBHOOK_SECRET: signing secret from the webhook endpoint (whsec_...)
# Webhook endpoint: POST {APP_URL}/api/stripe/webhook
# Enable events: customer.subscription.created, customer.subscription.updated, customer.subscription.deleted
# STRIPE_PUBLISHABLE_KEY: publishable key (pk_test_... / pk_live_...) — safe to expose to the browser
# Plan price IDs (recurring): PRO = Monthly plan, PREMIUM = Yearly plan
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO=
STRIPE_PRICE_PREMIUM=

# ─── Email (Resend) ───
# 1) Create an API key (starts with "re_")
# 2) For dev, you can use: GigConnection <onboarding@resend.dev>
RESEND_API_KEY=
EMAIL_FROM=GigConnection <onboarding@resend.dev>

# Support desk (shown on /support; admin alerts sent here)
SUPPORT_EMAIL=connectiongig@gmail.com
SUPPORT_PHONE=


SEED_ADMIN_EMAIL=connectiongig@gmail.com
SEED_ADMIN_PASSWORD=GagoPucaPrvi

# Optional: seed script superadmin (defaults: connectiongig@gmail.com / password123)
# SEED_ADMIN_EMAIL=
# SEED_ADMIN_PASSWORD=

# Legacy SMTP (optional; only used if RESEND_API_KEY is not set)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# ─── Production (VPS example: api.gig-connection.com) ───
# NODE_ENV=production
# MONGODB_URI=mongodb://127.0.0.1:27017/gigconnection
# FRONTEND_URL=https://gig-connection.com,https://www.gig-connection.com
# APP_URL=https://api.gig-connection.com
# UPLOAD_DIR=/var/www/gigconnection/data/uploads
# (Use new random secrets, not the dev placeholders above)
# Optional: newsletter unsubscribe link signing (defaults to JWT_ACCESS_SECRET)
# NEWSLETTER_UNSUBSCRIBE_SECRET=
